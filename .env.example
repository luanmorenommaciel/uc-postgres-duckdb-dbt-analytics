POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# DuckDB warehouse file the landing step writes to (Postgres is ATTACHed into it).
# Default path if unset: platform/warehouse/warehouse.duckdb
# DUCKDB_DATABASE=platform/warehouse/warehouse.duckdb

# Chaos generator: injection is SILENT by default (no row written to
# injected_incidents). Opt in to recording ground truth per-run with
# `make inject FAILURE=... RECORD=1` (or `gen inject ... --record`).
